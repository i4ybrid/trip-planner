# Backend Environment Variables

# Server
NODE_ENV=development
PORT=4000

# Logging
LOG_LEVEL=DEBUG

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tripplanner"

# JWT Authentication
JWT_SECRET="your-super-secret-jwt-key-min-32-characters-long"

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:3000"

# Redis (for Socket.io adapter in production)
REDIS_URL="redis://localhost:6379"

# File Storage
# For local storage: use a path like "/app/uploads" or leave empty for default "./uploads"
# For remote storage: use a full URL like "https://cdn.example.com/uploads"
MEDIA_STORAGE_URL=""

# File Storage (S3)
S3_ENDPOINT="https://s3.amazonaws.com"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET="tripplanner-dev"
S3_REGION="us-east-1"

# Email (SendGrid)
SENDGRID_API_KEY=""
EMAIL_FROM="noreply@tripplanner.app"

# Push Notifications (FCM)
FCM_SERVER_KEY=""
